{
  "manifest_version": 3,
  "name": "Vanish — Digital Footprint Scanner",
  "version": "1.0.6",
  "description": "Discover every account and subscription linked to your email. Part of the Vanish privacy suite.",

  "permissions": [
    "identity",
    "storage"
  ],

  "oauth2": {
    "client_id": "676683456741-6teg884l0q55m9b997sv9e91jcvs2o1m.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Vanish",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://sudo-wheat.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "externally_connectable": {
    "matches": [
      "https://sudo-wheat.vercel.app/*"
    ]
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
